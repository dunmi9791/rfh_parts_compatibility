<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List ── -->
    <record id="view_spare_vehicle_engine_list" model="ir.ui.view">
        <field name="name">spare.vehicle.engine.list</field>
        <field name="model">spare.vehicle.engine</field>
        <field name="arch" type="xml">
            <list string="Engine Variants">
                <field name="model_id"/>
                <field name="name"/>
                <field name="fuel_type"/>
                <field name="displacement"/>
                <field name="power_hp" string="hp"/>
            </list>
        </field>
    </record>

    <!-- ── Form ── -->
    <record id="view_spare_vehicle_engine_form" model="ir.ui.view">
        <field name="name">spare.vehicle.engine.form</field>
        <field name="model">spare.vehicle.engine</field>
        <field name="arch" type="xml">
            <form string="Engine Variant">
                <sheet>
                    <div class="oe_title">
                        <label for="model_id"/>
                        <h1><field name="model_id" options="{'no_create': True}"/></h1>
                        <label for="name" string="Engine"/>
                        <h2><field name="name" placeholder="e.g. 2.8L 1GD-FTV Diesel"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="fuel_type"/>
                            <field name="displacement"/>
                        </group>
                        <group>
                            <field name="cylinders"/>
                            <field name="power_hp"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_spare_vehicle_engine" model="ir.actions.act_window">
        <field name="name">Engine Variants</field>
        <field name="res_model">spare.vehicle.engine</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
