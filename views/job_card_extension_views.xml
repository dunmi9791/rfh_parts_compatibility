<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         1. Extend rfh.vehicle form — add engine_id field
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_rfh_vehicle_engine_inherit" model="ir.ui.view">
        <field name="name">rfh.vehicle.engine.inherit</field>
        <field name="model">rfh.vehicle</field>
        <field name="inherit_id" ref="rfh_workshop_management.view_rfh_vehicle_form"/>
        <field name="arch" type="xml">
            <!-- Add engine after the model field -->
            <field name="model_id" position="after">
                <field name="engine_id"
                       domain="[('model_id', '=', model_id)]"
                       options="{'no_create': True}"
                       placeholder="Select engine variant…"/>
            </field>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         2. Extend rfh.job.card form — add "Find Parts for Vehicle" button
            and compatibility indicator on the parts tab
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_rfh_job_card_parts_compat_inherit" model="ir.ui.view">
        <field name="name">rfh.job.card.parts.compat.inherit</field>
        <field name="model">rfh.job.card</field>
        <field name="inherit_id" ref="rfh_workshop_management.jobcard_view_form"/>
        <field name="arch" type="xml">

            <!-- "Find Compatible Parts" button in the header -->
            <xpath expr="//header" position="inside">
                <button string="🔍 Find Parts for Vehicle"
                        type="object"
                        name="action_open_part_finder"
                        class="btn-secondary"
                        title="Open the part finder pre-filled with this vehicle's make, model and engine"/>
            </xpath>

            <!-- Add compatibility warning column to the parts list -->
            <xpath expr="//field[@name='part_ids']" position="inside">
                <list editable="bottom">
                    <field name="product_id"/>
                    <field name="quantity"/>
                    <field name="qty_available" widget="float" readonly="1"/>
                    <field name="compatibility_warning" string="Compatibility" readonly="1"/>
                </list>
            </xpath>

        </field>
    </record>

</odoo>
