<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         1. Inherit product.template form — add Vehicle Compatibility tab
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_product_template_rfh_compatibility" model="ir.ui.view">
        <field name="name">product.template.rfh.compatibility</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Smart button: compatible vehicle count -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_view_compatibility"
                        icon="fa-car"
                        invisible="compatible_vehicle_count == 0">
                    <field name="compatible_vehicle_count"
                           widget="statinfo"
                           string="Vehicles"/>
                </button>
            </div>

            <!-- Workshop Part flag next to the product type -->
            <field name="type" position="after">
                <field name="is_workshop_part"/>
            </field>

            <!-- New tab after "Sales" tab -->
            <page name="sales" position="after">
                <page string="Vehicle Compatibility" name="vehicle_compatibility">
                    <div class="alert alert-info" role="alert"
                         invisible="compatible_vehicle_count != 0">
                        <p>
                            <strong>No vehicle compatibility defined yet.</strong>
                            Add rows below to specify which vehicles this part fits.
                            You can then use the <em>Find Parts for Vehicle</em>
                            wizard to look up compatible parts from any repair job.
                        </p>
                    </div>
                    <field name="compatibility_ids"
                           context="{'default_product_tmpl_id': active_id}">
                        <list editable="bottom">
                            <field name="vehicle_make_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="vehicle_model_id"
                                   options="{'no_create_edit': True}"
                                   domain="[('make_id','=',vehicle_make_id)]"/>
                            <field name="engine_id"
                                   optional="show"
                                   domain="[('model_id','=',vehicle_model_id)]"/>
                            <field name="year_from" optional="show"/>
                            <field name="year_to"   optional="show"/>
                            <field name="oem_part_number" optional="show"/>
                            <field name="fitment_notes" optional="hide"/>
                        </list>
                    </field>
                </page>
            </page>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         2. standalone list/search for spare.product.compatibility
    ══════════════════════════════════════════════════════════════════════════ -->
    <record id="view_spare_product_compatibility_list" model="ir.ui.view">
        <field name="name">spare.product.compatibility.list</field>
        <field name="model">spare.product.compatibility</field>
        <field name="arch" type="xml">
            <list string="Part–Vehicle Compatibility">
                <field name="product_tmpl_id"/>
                <field name="vehicle_make_id"/>
                <field name="vehicle_model_id"/>
                <field name="engine_id" optional="show"/>
                <field name="year_from" optional="show"/>
                <field name="year_to"   optional="show"/>
                <field name="oem_part_number" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_spare_product_compatibility_search" model="ir.ui.view">
        <field name="name">spare.product.compatibility.search</field>
        <field name="model">spare.product.compatibility</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_tmpl_id" string="Part"/>
                <field name="vehicle_make_id"/>
                <field name="vehicle_model_id"/>
                <field name="oem_part_number"/>
                <group expand="0" string="Group By">
                    <filter string="Make"  name="grp_make"  context="{'group_by':'vehicle_make_id'}"/>
                    <filter string="Model" name="grp_model" context="{'group_by':'vehicle_model_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_spare_product_compatibility" model="ir.actions.act_window">
        <field name="name">Part–Vehicle Compatibility</field>
        <field name="res_model">spare.product.compatibility</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
